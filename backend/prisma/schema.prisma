generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  RECEPCIONISTA
  MECHANIC
  CLIENT
}

enum WorkOrderStatus {
  PENDIENTE
  EN_PROCESO
  TERMINADA
  ENTREGADA
}

model Workshop {
  id            String         @id @default(cuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  clients       Client[]
  vehicles      Vehicle[]
  inventory     InventoryItem[]
  workOrders    WorkOrder[]
  chatMessages  ChatMessage[]
  appointments  Appointment[]
  quotes        Quote[]
  invoices      Invoice[]
  notifications Notification[]
  activityLogs  ActivityLog[]
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  password    String
  fullName    String
  role        Role
  workshopId  String
  workshop    Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  assignedOrders WorkOrder[] @relation("MechanicOrders")
  sentMessages ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Client {
  id          String      @id @default(cuid())
  workshopId  String
  workshop    Workshop    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String?
  email       String?
  vehicles    Vehicle[]
  workOrders  WorkOrder[]
  appointments Appointment[]
  quotes      Quote[]
  invoices    Invoice[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Vehicle {
  id          String      @id @default(cuid())
  workshopId  String
  workshop    Workshop    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plate       String
  brand       String
  model       String
  year        Int?
  workOrders  WorkOrder[]
  appointments Appointment[]
  quotes      Quote[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([workshopId, plate])
}

model InventoryItem {
  id          String      @id @default(cuid())
  workshopId  String
  workshop    Workshop    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  stock       Int         @default(0)
  unitPrice   Float       @default(0)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model WorkOrder {
  id            String          @id @default(cuid())
  number        String
  workshopId    String
  workshop      Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicleId     String
  vehicle       Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  mechanicId    String?
  mechanic      User?           @relation("MechanicOrders", fields: [mechanicId], references: [id], onDelete: SetNull)
  status        WorkOrderStatus @default(PENDIENTE)
  diagnosis     String?
  notes         String?
  laborCost     Float           @default(0)
  partsCost     Float           @default(0)
  totalCost     Float           @default(0)
  orderItems    OrderItem[]
  chatMessages  ChatMessage[]
  quote         Quote?
  invoice       Invoice?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([workshopId, number])
}

model OrderItem {
  id          String        @id @default(cuid())
  orderId     String
  order       WorkOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  quantity    Int           @default(1)
  unitPrice   Float         @default(0)
  subtotal    Float         @default(0)
}

model ChatMessage {
  id          String     @id @default(cuid())
  workshopId  String
  workshop    Workshop   @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String?
  receiver    User?      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
  orderId     String?
  order       WorkOrder? @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content     String
  isEdited    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Appointment {
  id          String    @id @default(cuid())
  workshopId  String
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date        DateTime
  reason      String?
  status      String    @default("PENDIENTE")
  workOrderId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Quote {
  id          String    @id @default(cuid())
  workshopId  String
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  workOrderId String?   @unique
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  amount      Float     @default(0)
  status      String    @default("BORRADOR")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id          String    @id @default(cuid())
  workshopId  String
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workOrderId String    @unique
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  amount      Float     @default(0)
  paid        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id          String    @id @default(cuid())
  workshopId  String
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  userId      String?
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id          String    @id @default(cuid())
  workshopId  String
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  userId      String?
  action      String
  metadata    Json?
  createdAt   DateTime  @default(now())
}
